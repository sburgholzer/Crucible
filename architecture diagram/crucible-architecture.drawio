        <mxCell id="zoneG" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f5a623;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;" value="⑥ Cost Profile — Target: under $50/month all-in" vertex="1">
