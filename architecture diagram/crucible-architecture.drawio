        </mxCell>
        <mxCell id="costSkipBody" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#333333;" value="QuickSight — $9/user/mo + per-session. Replaced with React tab in chaos panel.&#xa;&#xa;OpenSearch Serverless — 2 OCU minimum ≈ $700/mo idle. Replaced with Bedrock Titan + in-Lambda FAISS over S3 markdown.&#xa;&#xa;Bedrock Knowledge Base — needs a vector store backend. Skipped for v1; same job done by search-kb Lambda." vertex="1">
          <mxGeometry height="125" width="760" x="110" y="1962" as="geometry" />
        </mxCell>
        <mxCell id="costKeep" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="✓ Fixed costs we accept" vertex="1">
          <mxGeometry height="160" width="780" x="900" y="1930" as="geometry" />
        </mxCell>
        <mxCell id="costKeepBody" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#333333;" value="API Gateway HTTP APIs — $1.00 per million requests, no hourly. At demo traffic ≈ pennies. (Replaced ALBs that would have cost ~$32/mo idle.)&#xa;&#xa;Synthetics canaries at 5-min interval ≈ $10/mo, or trigger on-demand from the chaos panel = ~free.&#xa;&#xa;Route 53 hosted zone + health checks ≈ $1.50/mo.&#xa;&#xa;DDB on-demand, Lambda, CloudFront, S3, EventBridge, FIS, X-Ray, CloudWatch alarms — all pay-per-use, pennies at demo traffic. New all-in target: ~$10–15/mo idle." vertex="1">
          <mxGeometry height="125" width="760" x="910" y="1962" as="geometry" />
        </mxCell>
        <mxCell id="costGuard" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#f5a623;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" value="🛡 Guardrails &amp; v2 upgrade path" vertex="1">
          <mxGeometry height="160" width="830" x="1700" y="1930" as="geometry" />
        </mxCell>
        <mxCell id="costGuardBody" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=11;fontColor=#333333;" value="AWS Budgets hard cap at $50/mo with EventBridge action → Lambda that disables chaos-api on breach.&#xa;&#xa;Blast radius: chaos-trigger IAM role allows ssm:PutParameter only on arn:...:parameter/crucible/* and FIS Lambda actions only on resources tagged Project=Crucible. Physically can&#39;t touch other projects.&#xa;&#xa;Bedrock Agent: token budget per invocation, Claude Haiku for the agent model. v2 upgrade path: Bedrock KB + Aurora Serverless v2 pgvector (~$43/mo) — frame as deliberate v1 simplification." vertex="1">
          <mxGeometry height="125" width="810" x="1710" y="1962" as="geometry" />
        </mxCell>
